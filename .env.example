# ── Backend ───────────────────────────────────────────────────────────────────
MODEL_PATH=./backend/dog_model.pth
CHROMA_PATH=./chroma_data
CORS_ORIGINS=http://localhost

# Minimum cosine similarity (0–1) for /match results to be returned
SIMILARITY_THRESHOLD=0.45

# Minimum cosine similarity to trigger an automatic inbox notification
NOTIFY_THRESHOLD=0.45

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=dogfinder
POSTGRES_PASSWORD=dogfinder123
POSTGRES_DB=dogfinder
DB_URL=postgresql://dogfinder:dogfinder123@postgres:5432/dogfinder

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# ── Email Notifications (optional — leave SMTP_HOST empty to disable) ─────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=DogFinder <noreply@dogfinder.app>
APP_BASE_URL=http://localhost

# ── Frontend ──────────────────────────────────────────────────────────────────
# Empty = use relative /api path (correct for Docker/nginx setup)
# Set to http://localhost:8000 only for local dev without Docker
VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://localhost:8000
